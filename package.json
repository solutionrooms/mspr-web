{
  "name": "mspr-port",
  "version": "0.0.1",
  "private": true,
  "description": "Bit-exact TypeScript port of MS Paint Racers (Box2DFlash 2.0.2 engine + software-faithful WebGL renderer), with the golden-trace oracle rig.",
  "type": "module",
  "scripts": {
    "bootstrap": "bash tools/bootstrap.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "box2d:sync": "node tools/sync-box2d.mjs",
    "box2d:check": "node tools/sync-box2d.mjs --check",
    "extract:data": "python3 tools/extract_data.py",
    "atlas:ffdec": "node tools/atlas/ffdec-export.mjs",
    "atlas:build": "node tools/atlas/build-atlas.mjs",
    "atlas:road": "node tools/atlas/build-road-textures.mjs",
    "spike:road": "node tools/render-spike/run-road-spike.mjs",
    "spike:ref": "node tools/render-spike/build-ref.mjs",
    "spike:ruffle": "node tools/render-spike/run-ruffle.mjs",
    "spike:webgl": "node tools/render-spike/run-webgl.mjs",
    "spike:diff": "node tools/render-spike/diff.mjs",
    "spike": "npm run spike:ref && npm run spike:ruffle && npm run spike:webgl && npm run spike:diff",
    "oracle:build:a0": "node tools/oracle/build-harness.mjs tools/oracle/harness-a0-coast.as",
    "oracle:capture:a0": "node tools/oracle/capture-lines.mjs tools/oracle/build/harness-a0-coast.swf test/goldens/a0-coast.json --done DONE",
    "oracle:build:roadsegs": "node tools/oracle/build-harness.mjs tools/oracle/harness-roadsegs.as",
    "oracle:capture:roadsegs": "node tools/oracle/capture-lines.mjs tools/oracle/build/harness-roadsegs.swf test/goldens/road-coast.json --tags RSEG --done DONE",
    "oracle:build:freefall": "node tools/oracle/build-harness.mjs tools/oracle/harness-freefall.as",
    "oracle:capture:freefall": "node tools/oracle/capture-lines.mjs tools/oracle/build/harness-freefall.swf test/goldens/m0-m1-freefall.json --done DONE",
    "oracle:build:shapes": "node tools/oracle/build-harness.mjs tools/oracle/harness-shapes.as",
    "oracle:capture:shapes": "node tools/oracle/capture-lines.mjs tools/oracle/build/harness-shapes.swf test/goldens/m2a-shapes.json --done DONE",
    "oracle:build:broadphase": "node tools/oracle/build-harness.mjs tools/oracle/harness-broadphase.as",
    "oracle:capture:broadphase": "node tools/oracle/capture-lines.mjs tools/oracle/build/harness-broadphase.swf test/goldens/m2b-broadphase.json --done DONE",
    "oracle:build:collide": "node tools/oracle/build-harness.mjs tools/oracle/harness-collide.as",
    "oracle:capture:collide": "node tools/oracle/capture-lines.mjs tools/oracle/build/harness-collide.swf test/goldens/m3a-collide.json --done DONE",
    "oracle:build:contact": "node tools/oracle/build-harness.mjs tools/oracle/harness-contact.as",
    "oracle:capture:contact": "node tools/oracle/capture-lines.mjs tools/oracle/build/harness-contact.swf test/goldens/m3b-contact.json --done DONE",
    "oracle:build:solver": "node tools/oracle/build-harness.mjs tools/oracle/harness-solver.as",
    "oracle:capture:solver": "node tools/oracle/capture-lines.mjs tools/oracle/build/harness-solver.swf test/goldens/m4-solver.json --done DONE",
    "oracle:build:sleep": "node tools/oracle/build-harness.mjs tools/oracle/harness-sleep.as",
    "oracle:capture:sleep": "node tools/oracle/capture-lines.mjs tools/oracle/build/harness-sleep.swf test/goldens/m5-sleep.json --done DONE",
    "oracle:build:revolute": "node tools/oracle/build-harness.mjs tools/oracle/harness-revolute.as",
    "oracle:capture:revolute": "node tools/oracle/capture-lines.mjs tools/oracle/build/harness-revolute.swf test/goldens/m6-revolute.json --done DONE",
    "oracle:build:joints2": "node tools/oracle/build-harness.mjs tools/oracle/harness-joints2.as",
    "oracle:capture:joints2": "node tools/oracle/capture-lines.mjs tools/oracle/build/harness-joints2.swf test/goldens/m6-joints2.json --done DONE",
    "oracle:build:toi": "node tools/oracle/build-harness.mjs tools/oracle/harness-toi.as",
    "oracle:capture:toi": "node tools/oracle/capture-lines.mjs tools/oracle/build/harness-toi.swf test/goldens/m7-toi.json --done DONE",
    "dev": "vite",
    "build:web": "vite build"
  },
  "devDependencies": {
    "@ruffle-rs/ruffle": "^0.3.0",
    "jpeg-js": "^0.4.4",
    "pngjs": "^7.0.0",
    "puppeteer": "^23.11.1",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.9"
  }
}
